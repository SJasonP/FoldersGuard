# Local macOS release signing and notarization settings.
# Copy this file to config/macos-release.env and edit the values for your Mac.
# The config/ directory is intentionally gitignored.

APPLE_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_NOTARY_KEYCHAIN_PROFILE="apple-notary"

# Defaults are usually fine.
WAILS_PLATFORM="darwin/universal"
DIST_DIR="dist/macos"

# Optional local workflow switches.
# SKIP_BUILD=1
# SKIP_NOTARIZE=1

# Alternative to APPLE_NOTARY_KEYCHAIN_PROFILE.
# Prefer the keychain profile above; do not commit real credentials.
# APPLE_ID="apple-id@example.com"
# APPLE_TEAM_ID="TEAMID"
# APPLE_APP_PASSWORD="app-specific-password"
